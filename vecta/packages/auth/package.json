{
  "name": "@vecta/auth",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./middleware": {
      "types": "./src/middleware.ts",
      "default": "./src/middleware.ts"
    },
    "./single-use-token": {
      "types": "./src/single-use-token.ts",
      "default": "./src/single-use-token.ts"
    },
    "./landlord-access": {
      "types": "./src/landlord-access.ts",
      "default": "./src/landlord-access.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vecta/database": "*",
    "@vecta/types": "*",
    "@vecta/logger": "*",
    "@vecta/crypto": "*",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.14",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/express": "^4.17.21",
    "typescript": "^5.4.5"
  }
}
