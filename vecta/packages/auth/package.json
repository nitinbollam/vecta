{
  "name": "@vecta/auth",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./single-use-token": {
      "types": "./dist/single-use-token.d.ts",
      "default": "./dist/single-use-token.js"
    },
    "./landlord-access": {
      "types": "./dist/landlord-access.d.ts",
      "default": "./dist/landlord-access.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vecta/database": "*",
    "@vecta/types": "*",
    "@vecta/logger": "*",
    "@vecta/crypto": "*",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.14",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/express": "^4.17.21",
    "typescript": "^5.4.5"
  }
}
