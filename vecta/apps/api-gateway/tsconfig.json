{
  // rootDir must be "../.." (not "./src"): routes compile shared TS under ../../services and ../../packages/providers.
  // dist/ mirrors that layout (e.g. dist/apps/api-gateway/src/server.js). See RENDER_BUILD.md for Render ls dist/.
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": false,
    "esModuleInterop": true,
    "noEmit": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@vecta/logger": ["../../packages/logger/src/index.ts"],
      "@vecta/database": ["../../packages/database/src/index.ts"],
      "@vecta/crypto": ["../../packages/crypto/src/index.ts"],
      "@vecta/storage": ["../../packages/storage/src/index.ts"],
      "@vecta/auth": ["../../packages/auth/src/index.ts"],
      "@vecta/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../services/**/*.ts",
    "../../packages/providers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../services/**/server.ts"
  ]
}
