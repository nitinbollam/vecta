{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "src",
    "src/types/**/*.ts",
    "../../services/**/*.ts",
    "../../packages/providers/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
