# =============================================================================
# Render — Compliance AI (Python / FastAPI)
# Dashboard → Environment → Add from .env
#
# Startup requires all four values below (see apps/compliance-ai/src/main.py).
# =============================================================================

NODE_ENV=production

# Link Postgres + Redis in the dashboard, or uncomment:
# DATABASE_URL=
# REDIS_URL=

# Required — service will not start without both keys (fill before deploy)
OPENAI_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=CHANGE_ME

# CORS: gateway origin (your API Web Service URL)
API_GATEWAY_URL=https://your-api-gateway.onrender.com
