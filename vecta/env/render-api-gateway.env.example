# =============================================================================
# Render — API Gateway (Web Service)
# Dashboard → Environment → Add from .env  (paste or upload this file after
# filling secrets). Replace every CHANGE_ME / your_* placeholder.
#
# Render injects: PORT, RENDER=true. Link Postgres + Redis from the same
# blueprint or set DATABASE_URL / REDIS_URL manually.
# =============================================================================

# --- Required for the process to listen (Render sets PORT automatically) ---
NODE_ENV=production
SERVICE_NAME=vecta-api-gateway

# --- Postgres / Redis ---
# Prefer: Render Dashboard → link Postgres + Redis (do not define empty DATABASE_URL here).
# Or paste external URLs (uncomment and fill):
# DATABASE_URL=postgresql://...
# REDIS_URL=rediss://...

# Postgres TLS: on Render leave unset (app uses RENDER=true). Else see root .env.example.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# --- CORS: comma-separated browser origins (no spaces). REQUIRED in production. ---
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-landlord-app.vercel.app

# --- JWT (RS256) — use literal \n in PEM when pasting one line, or multiline in dashboard ---
VECTA_JWT_PRIVATE_KEY=CHANGE_ME
VECTA_JWT_PUBLIC_KEY=CHANGE_ME
VECTA_JWT_ISSUER=vecta.io
VECTA_JWT_AUDIENCE=vecta-platform

# --- Crypto / HMAC (required before PII encrypt or signed internal calls) ---
VECTA_FIELD_ENCRYPTION_KEY=CHANGE_ME_min_32_chars
VECTA_ENCRYPTION_SALT=vecta-pii-salt-v1
VECTA_HMAC_SECRET=CHANGE_ME
INTERNAL_SERVICE_SECRET=CHANGE_ME

# --- Upstream services (set after each service has a URL) ---
COMPLIANCE_AI_URL=https://your-compliance-ai.onrender.com
HOUSING_SERVICE_URL=http://housing-service:4003
API_GATEWAY_URL=https://your-api-gateway.onrender.com

# --- Webhooks & product URLs ---
DIDIT_WEBHOOK_SECRET=
UNIT_WEBHOOK_SECRET=
CHECKR_WEBHOOK_SECRET=
COMPLIANCE_OFFICER_KEY=
VERIFICATION_BASE_URL=https://verify.vecta.io
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# --- Optional logging ---
LOG_LEVEL=info

# --- AWS S3 (@vecta/storage — housing downloads, identity docs, etc.) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_IDENTITY_BUCKET=vecta-identity
S3_HOUSING_BUCKET=vecta-housing
S3_AUDIT_BUCKET=vecta-compliance
# S3_ENDPOINT=

# --- Plaid / Nova / eSIM (housing & mobility routes) ---
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_TOKEN_ENCRYPTION_KEY=
NOVA_CREDIT_API_KEY=
ESIM_GO_API_KEY=
ESIM_PLAN_5G_UNLIMITED=
ESIM_PLAN_5G_10GB=
ESIM_PLAN_LTE_5GB=

# --- OpenAI (embeddings / features that call OpenAI from gateway path) ---
OPENAI_API_KEY=

# --- Didit / Unit (identity flows pulled in via monorepo services) ---
DIDIT_API_URL=https://api.didit.me
DIDIT_API_KEY=
UNIT_API_TOKEN=
UNIT_API_URL=https://api.s.unit.sh
UNIT_BASE_URL=https://api.s.unit.sh
UNIT_WEBHOOK_SECRET=
UNIT_DEPOSIT_PRODUCT_ID=
