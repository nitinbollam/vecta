{
  "name": "@vecta/api-gateway",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && node scripts/write-render-entry.cjs",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "reencrypt-pii": "ts-node --transpile-only -r dotenv/config scripts/reencrypt-pii.ts"
  },
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "@vecta/auth": "*",
    "@vecta/crypto": "*",
    "@vecta/database": "*",
    "@vecta/logger": "*",
    "@vecta/storage": "*",
    "@vecta/types": "*",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "plaid": "^30.0.0",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/node": "^20.12.12",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
