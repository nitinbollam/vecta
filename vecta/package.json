{
  "name": "vecta",
  "version": "1.0.0",
  "private": true,
  "description": "Vecta — Life-as-a-Service for F-1 International Students",
  "workspaces": [
    "frontend/student-app",
    "frontend/landlord-portal",
    "backend/api-gateway",
    "backend/services/identity-service",
    "backend/services/banking-service",
    "backend/services/housing-service",
    "backend/services/mobility-service",
    "backend/services/compliance-service",
    "backend/services/audit-service",
    "backend/shared/auth",
    "backend/shared/crypto",
    "backend/shared/database",
    "backend/shared/logger",
    "backend/shared/providers",
    "backend/shared/storage",
    "backend/shared/types"
  ],
  "scripts": {
    "dev":              "turbo run dev",
    "build":            "turbo run build",
    "test":             "turbo run test",
    "lint":             "turbo run lint",
    "dev:frontend":     "turbo run dev --filter=./frontend/*",
    "dev:backend":      "turbo run dev --filter=./backend/*",
    "dev:gateway":      "turbo run dev --filter=@vecta/api-gateway",
    "dev:services":     "turbo run dev --filter=./backend/services/*",
    "build:shared":     "turbo run build --filter=./backend/shared/*",
    "db:migrate":       "node scripts/run-migrations.js",
    "scripts:reencrypt-pii": "npm run reencrypt-pii --workspace=@vecta/api-gateway"
  },
  "devDependencies": {
    "@types/jest":    "^29.5.12",
    "@types/node":    "^20.12.12",
    "@types/pg":      "^8.11.0",
    "jest":           "^29.7.0",
    "ts-jest":        "^29.2.5",
    "turbo":          "^2.4.0",
    "typescript":     "^5.4.5",
    "eslint":         "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser":        "^7.10.0",
    "prettier":       "^3.2.5",
    "pg":             "^8.13.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "react-native-worklets": "0.7.2"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
