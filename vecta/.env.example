# =============================================================================
# Vecta Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://vecta:vecta_dev_password@localhost:5432/vecta_db
DB_POOL_MAX=20
# Supabase (hosted Postgres + pgvector): Project Settings → Database → URI
# Use the "Session" or "Transaction" pooler URL for serverless; direct (5432) works for long-lived APIs (e.g. Render).
# Append sslmode=require if not already in the string. Enable pgvector: SQL → CREATE EXTENSION IF NOT EXISTS vector;
# Docs: https://supabase.com/docs/guides/database/connecting-to-postgres

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# JWT / Authentication
# Generate keypair: openssl genrsa -out private.pem 4096
#                   openssl rsa -in private.pem -pubout -out public.pem
# ---------------------------------------------------------------------------
VECTA_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
VECTA_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
VECTA_JWT_ISSUER=vecta.io
VECTA_JWT_AUDIENCE=vecta-platform
VECTA_JWT_EXPIRY=720h

# ---------------------------------------------------------------------------
# Field encryption (AES-256-GCM)
# Generate: openssl rand -base64 48
# ---------------------------------------------------------------------------
VECTA_FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_a_48_char_base64_key
VECTA_ENCRYPTION_SALT=vecta-pii-salt-v1
VECTA_HMAC_SECRET=CHANGE_ME_generate_a_64_char_secret

# ---------------------------------------------------------------------------
# Didit (NFC Passport Verification)
# https://docs.didit.me
# ---------------------------------------------------------------------------
DIDIT_CLIENT_ID=your_didit_client_id
DIDIT_CLIENT_SECRET=your_didit_client_secret
DIDIT_BASE_URL=https://api.didit.me/v1
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret
# Biometric thresholds — do NOT lower these below spec
DIDIT_LIVENESS_THRESHOLD=0.92
DIDIT_FACIAL_MATCH_THRESHOLD=0.90

# ---------------------------------------------------------------------------
# Unit.co (Banking-as-a-Service)
# https://docs.unit.co
# ---------------------------------------------------------------------------
UNIT_API_TOKEN=your_unit_api_token
UNIT_BASE_URL=https://api.unit.co
UNIT_WEBHOOK_SECRET=your_unit_webhook_secret
UNIT_ORG_ID=your_unit_org_id

# ---------------------------------------------------------------------------
# Plaid
# https://plaid.com/docs
# ---------------------------------------------------------------------------
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# sandbox | development | production
PLAID_BASE_URL=https://sandbox.plaid.com

# ---------------------------------------------------------------------------
# Nova Credit
# https://docs.novacredit.com
# ---------------------------------------------------------------------------
NOVA_CREDIT_API_KEY=your_nova_credit_api_key
NOVA_CREDIT_BASE_URL=https://api.novacredit.com

# ---------------------------------------------------------------------------
# eSIM Go
# https://docs.esim.com
# ---------------------------------------------------------------------------
ESIM_GO_API_KEY=your_esim_go_api_key
ESIM_GO_BASE_URL=https://api.esim-go.com/v2.3

# ---------------------------------------------------------------------------
# Lemonade Insurance
# https://developers.lemonade.com
# ---------------------------------------------------------------------------
LEMONADE_API_KEY=your_lemonade_api_key
LEMONADE_PARTNER_ID=your_lemonade_partner_id
LEMONADE_API_URL=https://api.lemonade.com

# ---------------------------------------------------------------------------
# AWS S3
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_IDENTITY_BUCKET=vecta-identity
S3_HOUSING_BUCKET=vecta-housing
S3_AUDIT_BUCKET=vecta-compliance
# For local dev with MinIO / LocalStack:
# S3_ENDPOINT=http://localhost:9000

# ---------------------------------------------------------------------------
# OpenAI (roommate embedding)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ---------------------------------------------------------------------------
# Anthropic Claude (insurance PDF analysis)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---------------------------------------------------------------------------
# Service URLs (for inter-service communication)
# ---------------------------------------------------------------------------
COMPLIANCE_AI_URL=http://compliance-ai:8000
IDENTITY_SERVICE_URL=http://identity-service:4001
BANKING_SERVICE_URL=http://banking-service:4002
HOUSING_SERVICE_URL=http://housing-service:4003
MOBILITY_SERVICE_URL=http://mobility-service:4004
AUDIT_SERVICE_URL=http://audit-service:4005

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Landlord Portal (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
VECTA_INTERNAL_API_URL=http://api-gateway:4000
# Server-side only — never expose to browser

# ---------------------------------------------------------------------------
# Student App (Expo)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_POSTHOG_KEY=your_posthog_key

# ---------------------------------------------------------------------------
# Verification portal base URL (for QR codes in LoC PDFs)
# ---------------------------------------------------------------------------
VERIFICATION_BASE_URL=https://verify.vecta.io

# ---------------------------------------------------------------------------
# SendGrid (transactional email)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@vecta.io

# SendGrid Dynamic Template IDs (set in SendGrid dashboard)
SG_TEMPLATE_LANDLORD_VERIFY=d-landlord-verify
SG_TEMPLATE_LANDLORD_UPGRADE=d-landlord-upgrade
SG_TEMPLATE_STUDENT_TOKEN_USED=d-student-token-used
SG_TEMPLATE_STUDENT_KYC_APPROVED=d-student-kyc-approved
SG_TEMPLATE_STUDENT_KYC_REJECTED=d-student-kyc-rejected
SG_TEMPLATE_LOC_GENERATED=d-loc-generated
SG_TEMPLATE_DSO_MEMO=d-dso-memo-ready

# ---------------------------------------------------------------------------
# Checkr (landlord background checks)
# ---------------------------------------------------------------------------
CHECKR_API_KEY=your_checkr_api_key
CHECKR_BASE_URL=https://api.checkr.com/v1
CHECKR_PACKAGE=tasker_pro
CHECKR_WEBHOOK_SECRET=your_checkr_webhook_secret

# ---------------------------------------------------------------------------
# ISO + PSI (student health insurance)
# ---------------------------------------------------------------------------
ISO_API_URL=https://api.isoa.org/v2
ISO_API_KEY=your_iso_api_key
PSI_API_URL=https://api.psiinsurance.com/v1
PSI_API_KEY=your_psi_api_key

# ---------------------------------------------------------------------------
# Internal service auth (service-to-service HMAC)
# ---------------------------------------------------------------------------
INTERNAL_SERVICE_SECRET=CHANGE_ME_generate_64_char_secret_for_internal_service_auth

# ---------------------------------------------------------------------------
# Admin
# ---------------------------------------------------------------------------
ADMIN_STREAM_KEY=CHANGE_ME_admin_stream_key_for_sse_dashboard

# ---------------------------------------------------------------------------
# Provider abstraction layer
# ---------------------------------------------------------------------------
BANKING_PROVIDER=unit               # unit | stripe
BANKING_PROVIDER_FALLBACK=stripe
IDENTITY_PROVIDER=didit             # didit | persona
IDENTITY_PROVIDER_FALLBACK=persona
BANK_DATA_PROVIDER=plaid            # plaid | mx
BANK_DATA_PROVIDER_FALLBACK=mx
CREDIT_PROVIDER=nova                # nova | fairplay
CREDIT_PROVIDER_FALLBACK=fairplay
ESIM_PROVIDER=esimgo                # esimgo | alosim
ESIM_PROVIDER_FALLBACK=alosim

# Stripe Treasury (banking fallback)
STRIPE_SECRET_KEY=sk_live_your_stripe_key

# MX (bank data fallback)
MX_CLIENT_ID=your_mx_client_id
MX_API_KEY=your_mx_api_key

# ---------------------------------------------------------------------------
# Compliance operations
# ---------------------------------------------------------------------------
COMPLIANCE_OFFICER_KEY=CHANGE_ME_officer_key_for_case_management
SLACK_COMPLIANCE_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook

# ---------------------------------------------------------------------------
# Key management (Ed25519 rotation)
# ---------------------------------------------------------------------------
# Comma-separated list of active key versions, latest last
KEY_VERSIONS=v1
# For rotation: KEY_VERSIONS=v1,v2 + add INTERNAL_SERVICE_SECRET_V2
# INTERNAL_SERVICE_SECRET_V2=new_secret_here
# After 30 days (cert expiry): KEY_VERSIONS=v2, remove V1 env vars
KEY_NOT_BEFORE_V1=2025-01-01T00:00:00Z
# KEY_NOT_AFTER_V1=2025-07-01T00:00:00Z  (set when retiring v1)

# ---------------------------------------------------------------------------
# Public anchor log (Gap 2)
# ---------------------------------------------------------------------------
S3_PUBLIC_ANCHOR_BUCKET=vecta-public-anchors
S3_PUBLIC_BASE_URL=https://vecta-public-anchors.s3.amazonaws.com
GITHUB_GIST_TOKEN=github_pat_your_token_here
GITHUB_ANCHOR_GIST_ID=your_gist_id_here

# ---------------------------------------------------------------------------
# Landlord portal (Vercel / production)
# ---------------------------------------------------------------------------
# Browser rewrites: /api/v1/* → gateway (no trailing slash)
# API_GATEWAY_URL=https://your-gateway.onrender.com
# SSR + Route Handlers (same URL as gateway)
# VECTA_INTERNAL_API_URL=https://your-gateway.onrender.com
# NEXT_PUBLIC_APP_URL=https://your-portal.vercel.app
# Optional admin dashboard: COMPLIANCE_AI_URL or COMPLIANCE_AI_INTERNAL_URL
