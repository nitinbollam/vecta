# =============================================================================
# Vecta — local & shared environment template
# Copy to .env at this folder (vecta/):  cp .env.example .env
# For Render bulk import use: env/render-api-gateway.env.example
# Never commit .env or env/local.env (see env/.gitignore).
# =============================================================================

# ---------------------------------------------------------------------------
# Core — API gateway & packages
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
SERVICE_NAME=vecta-api-gateway
LOG_LEVEL=debug

DATABASE_URL=postgresql://vecta:vecta_dev_password@localhost:5432/vecta_db
DB_POOL_MAX=20
# Hosted Postgres: append sslmode=require if needed. Optional overrides:
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
#
# One-time: DB already has migrations 001–006 applied? Baseline then apply newer files only:
# MIGRATION_MARK_BASELINE_UNTIL=007_tenant_trust_certificate_json.sql

REDIS_URL=redis://localhost:6379

# CORS (gateway server.ts reads ALLOWED_ORIGINS, not CORS_ORIGINS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ---------------------------------------------------------------------------
# JWT / Authentication
# openssl genrsa -out private.pem 4096
# openssl rsa -in private.pem -pubout -out public.pem
# ---------------------------------------------------------------------------
VECTA_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
VECTA_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
VECTA_JWT_ISSUER=vecta.io
VECTA_JWT_AUDIENCE=vecta-platform
VECTA_JWT_EXPIRY=720h

# ---------------------------------------------------------------------------
# Field encryption (AES-256-GCM) — ≥ 32 characters
# openssl rand -base64 48
# ---------------------------------------------------------------------------
VECTA_FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_a_48_char_base64_key
VECTA_ENCRYPTION_SALT=vecta-pii-salt-v1
VECTA_HMAC_SECRET=CHANGE_ME_generate_a_64_char_secret
LOC_SIGNING_KEY=generate_with_node_crypto_32_bytes_hex

# ---------------------------------------------------------------------------
# Didit (identity / NFC passport) — https://docs.didit.me
# ---------------------------------------------------------------------------
DIDIT_API_URL=https://api.didit.me
DIDIT_API_KEY=your_didit_api_key
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret
DIDIT_LIVENESS_THRESHOLD=0.92
DIDIT_FACIAL_MATCH_THRESHOLD=0.90

# ---------------------------------------------------------------------------
# Unit.co (banking) — https://docs.unit.co
# ---------------------------------------------------------------------------
UNIT_API_TOKEN=your_unit_api_token
UNIT_API_URL=https://api.s.unit.sh
UNIT_BASE_URL=https://api.s.unit.sh
UNIT_WEBHOOK_SECRET=your_unit_webhook_secret
UNIT_ORG_ID=your_unit_org_id
UNIT_DEPOSIT_PRODUCT_ID=your_deposit_product_id

# ---------------------------------------------------------------------------
# Plaid — https://plaid.com/docs
# ---------------------------------------------------------------------------
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_WEBHOOK_SECRET=
# 32-byte hex — openssl rand -hex 32
PLAID_TOKEN_ENCRYPTION_KEY=generate_with_node_crypto_32_bytes_hex

# ---------------------------------------------------------------------------
# Nova Credit — https://docs.novacredit.com
# ---------------------------------------------------------------------------
NOVA_CREDIT_API_KEY=your_nova_credit_api_key
NOVA_CREDIT_API_URL=https://api.novacredit.com/v1

# ---------------------------------------------------------------------------
# eSIM Go — https://docs.esim.com
# ---------------------------------------------------------------------------
ESIM_GO_API_KEY=your_esim_go_api_key
ESIM_GO_API_URL=https://api.esim-go.com/v2.3
ESIM_PLAN_5G_UNLIMITED=
ESIM_PLAN_5G_10GB=
ESIM_PLAN_LTE_5GB=

# ---------------------------------------------------------------------------
# Lemonade Insurance — https://developers.lemonade.com
# ---------------------------------------------------------------------------
LEMONADE_API_KEY=your_lemonade_api_key
LEMONADE_PARTNER_ID=your_lemonade_partner_id
LEMONADE_API_URL=https://api.lemonade.com

# ---------------------------------------------------------------------------
# AWS S3
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_IDENTITY_BUCKET=vecta-identity
S3_HOUSING_BUCKET=vecta-housing
S3_AUDIT_BUCKET=vecta-compliance
# S3_ENDPOINT=http://localhost:9000

# ---------------------------------------------------------------------------
# OpenAI / Anthropic
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---------------------------------------------------------------------------
# API gateway (public entry)
# ---------------------------------------------------------------------------
API_GATEWAY_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Microservice URLs — local dev (host machine; use Docker service names when
# all services run in Compose, e.g. http://identity-service:3001)
# ---------------------------------------------------------------------------
IDENTITY_SERVICE_URL=http://localhost:3001
BANKING_SERVICE_URL=http://localhost:3002
HOUSING_SERVICE_URL=http://localhost:3003
MOBILITY_SERVICE_URL=http://localhost:3004
COMPLIANCE_SERVICE_URL=http://localhost:3005
AUDIT_SERVICE_URL=http://localhost:3006
COMPLIANCE_AI_URL=http://localhost:3007

# ---------------------------------------------------------------------------
# Landlord Portal (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
VECTA_INTERNAL_API_URL=http://api-gateway:4000

# ---------------------------------------------------------------------------
# Student App (Expo)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_COMPLIANCE_AI_URL=http://localhost:3007
EXPO_PUBLIC_POSTHOG_KEY=your_posthog_key

# ---------------------------------------------------------------------------
# Email / verification links
# ---------------------------------------------------------------------------
VERIFICATION_BASE_URL=https://verify.vecta.io
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@vecta.io
SG_TEMPLATE_LANDLORD_VERIFY=d-landlord-verify
SG_TEMPLATE_LANDLORD_UPGRADE=d-landlord-upgrade
SG_TEMPLATE_STUDENT_TOKEN_USED=d-student-token-used
SG_TEMPLATE_STUDENT_KYC_APPROVED=d-student-kyc-approved
SG_TEMPLATE_STUDENT_KYC_REJECTED=d-student-kyc-rejected
SG_TEMPLATE_LOC_GENERATED=d-loc-generated
SG_TEMPLATE_DSO_MEMO=d-dso-memo-ready
SENDGRID_MAGIC_LINK_TEMPLATE_ID=placeholder
SENDGRID_LANDLORD_MAGIC_LINK_TEMPLATE_ID=placeholder
SENDGRID_KYC_APPROVED_TEMPLATE_ID=placeholder
SENDGRID_KYC_REJECTED_TEMPLATE_ID=placeholder
SENDGRID_LOC_READY_TEMPLATE_ID=placeholder
SENDGRID_TOKEN_USED_TEMPLATE_ID=placeholder
SENDGRID_LANDLORD_VERIFY_TEMPLATE_ID=placeholder

# ---------------------------------------------------------------------------
# Checkr (landlord background checks)
# ---------------------------------------------------------------------------
CHECKR_API_KEY=your_checkr_api_key
CHECKR_BASE_URL=https://api.checkr.com/v1
CHECKR_PACKAGE=tasker_pro
CHECKR_WEBHOOK_SECRET=your_checkr_webhook_secret

# ---------------------------------------------------------------------------
# ISO + PSI (student health insurance)
# ---------------------------------------------------------------------------
ISO_API_URL=https://api.isoa.org/v2
ISO_API_KEY=your_iso_api_key
PSI_API_URL=https://api.psiinsurance.com/v1
PSI_API_KEY=your_psi_api_key

# ---------------------------------------------------------------------------
# Internal service auth (HMAC between services)
# ---------------------------------------------------------------------------
INTERNAL_SERVICE_SECRET=CHANGE_ME_generate_64_char_secret_for_internal_service_auth

# ---------------------------------------------------------------------------
# Admin / compliance ops
# ---------------------------------------------------------------------------
ADMIN_STREAM_KEY=CHANGE_ME_admin_stream_key_for_sse_dashboard
COMPLIANCE_OFFICER_KEY=CHANGE_ME_officer_key_for_case_management
SLACK_COMPLIANCE_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook

# ---------------------------------------------------------------------------
# Provider abstraction — Vertical Fortress defaults
# In-house providers are now default; legacy APIs are fallbacks
# ---------------------------------------------------------------------------
BANKING_PROVIDER=vecta-ledger
BANKING_PROVIDER_FALLBACK=unit
IDENTITY_PROVIDER=vecta-id
IDENTITY_PROVIDER_FALLBACK=didit
BANK_DATA_PROVIDER=vecta-connect
BANK_DATA_PROVIDER_FALLBACK=plaid
CREDIT_PROVIDER=vecta-bridge
CREDIT_PROVIDER_FALLBACK=nova
INSURANCE_PROVIDER=vecta-mga
INSURANCE_PROVIDER_FALLBACK=lemonade
ESIM_PROVIDER=esimgo
ESIM_PROVIDER_FALLBACK=alosim
STRIPE_SECRET_KEY=sk_live_your_stripe_key
MX_CLIENT_ID=your_mx_client_id
MX_API_KEY=your_mx_api_key

# ---------------------------------------------------------------------------
# Vecta Ledger (Phase 2) — Column Bank or ClearBank sponsor
# ---------------------------------------------------------------------------
COLUMN_BANK_API_KEY=
COLUMN_BANK_API_URL=https://api.column.com
CLEARBANK_API_KEY=
CLEARBANK_API_URL=https://institution.clearbank.co.uk
VISA_BIN_PREFIX=453201
CARD_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
CVV_HMAC_SECRET=generate_64_char_secret
SPONSOR_ROUTING=021000021
KYC_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# ---------------------------------------------------------------------------
# Vecta Connect (Phase 4) — Open Banking connectors
# ---------------------------------------------------------------------------
# India — Account Aggregator (Setu)
SETU_AA_CLIENT_ID=
SETU_AA_CLIENT_SECRET=
# UK — TrueLayer Open Banking
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
# EU — Salt Edge PSD2
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=
# US — Direct OAuth
CHASE_OAUTH_CLIENT_ID=
BOFA_OAUTH_CLIENT_ID=
WELLS_OAUTH_CLIENT_ID=
CITI_OAUTH_CLIENT_ID=
USBANK_OAUTH_CLIENT_ID=

# ---------------------------------------------------------------------------
# Vecta Credit Bridge (Phase 4) — Bureau licenses
# ---------------------------------------------------------------------------
CIBIL_API_KEY=
CIBIL_API_URL=https://api.cibil.com/v1
CIBIL_MEMBER_ID=
BURO_DE_CREDITO_API_KEY=
BURO_DE_CREDITO_API_URL=https://api.burodecredito.com.mx/v1
EXPERIAN_UK_API_KEY=
EXPERIAN_UK_CLIENT_SECRET=
EXPERIAN_UK_API_URL=https://api.experian.co.uk/consumerservices/credit-profile/v2
EQUIFAX_CANADA_API_KEY=
EQUIFAX_CANADA_CLIENT_ID=
EQUIFAX_CANADA_API_URL=https://api.equifax.ca/v1

# ---------------------------------------------------------------------------
# Vecta MGA Insurance (Phase 3) — Boost Insurance paper carrier
# ---------------------------------------------------------------------------
BOOST_INSURANCE_API_KEY=
BOOST_INSURANCE_API_URL=https://api.boostinsurance.io
STATE_NATIONAL_API_KEY=
STATE_NATIONAL_API_URL=
MGA_LICENSE_NUMBER=

# ---------------------------------------------------------------------------
# Key rotation (Ed25519)
# ---------------------------------------------------------------------------
KEY_VERSIONS=v1
KEY_NOT_BEFORE_V1=2025-01-01T00:00:00Z

# ---------------------------------------------------------------------------
# Public anchor log
# ---------------------------------------------------------------------------
S3_PUBLIC_ANCHOR_BUCKET=vecta-public-anchors
S3_PUBLIC_BASE_URL=https://vecta-public-anchors.s3.amazonaws.com
GITHUB_GIST_TOKEN=github_pat_your_token_here
GITHUB_ANCHOR_GIST_ID=your_gist_id_here

# ---------------------------------------------------------------------------
# Other (compliance-service, mobility, etc.)
# ---------------------------------------------------------------------------
OFAC_SCREENING_API_KEY=
FLIGHT_RECORDER_HMAC_KEY=
LESSOR_RENTAL_INCOME_PCT=0.30
